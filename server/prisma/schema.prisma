generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum RequestStatus { CREATED SENT_TO_SUPPLIER RECEIVED_BY_SUPPLIER ACCEPTED REJECTED INVOICE_UPLOADED VALUED DELIVERED CLOSED }
enum Priority { BAJA MEDIA ALTA URGENTE }
enum AttachmentType { INVOICE REMITO GENERAL }

model Role { id Int @id @default(autoincrement()) name String @unique users User[] @@map("roles") }
model Supplier { id Int @id @default(autoincrement()) name String cuit String? email String? phone String? address String? users User[] requests Request[] createdAt DateTime @default(now()) updatedAt DateTime @updatedAt @@map("suppliers") }
model User { id Int @id @default(autoincrement()) name String email String @unique password String roleId Int supplierId Int? active Boolean @default(true) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt role Role @relation(fields:[roleId], references:[id]) supplier Supplier? @relation(fields:[supplierId], references:[id]) requests Request[] @relation("RequesterRequests") authorizedRequests Request[] @relation("AuthorizerRequests") histories RequestStatusHistory[] attachments Attachment[] @@map("users") }
model Request { id Int @id @default(autoincrement()) code String @unique requesterId Int authorizerId Int supplierId Int area String observations String? authorizedPickupPerson String priority Priority @default(MEDIA) status RequestStatus @default(CREATED) supplierObservations String? valuedAmount Decimal? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt requester User @relation("RequesterRequests", fields:[requesterId], references:[id]) authorizer User @relation("AuthorizerRequests", fields:[authorizerId], references:[id]) supplier Supplier @relation(fields:[supplierId], references:[id]) items RequestItem[] invoice Invoice? remito Remito? history RequestStatusHistory[] attachments Attachment[] @@map("requests") }
model RequestItem { id Int @id @default(autoincrement()) requestId Int material String quantity Decimal unit String @default("unidad") request Request @relation(fields:[requestId], references:[id], onDelete:Cascade) @@map("request_items") }
model Invoice { id Int @id @default(autoincrement()) requestId Int @unique number String date DateTime amount Decimal observations String? attachmentId Int? createdAt DateTime @default(now()) request Request @relation(fields:[requestId], references:[id]) attachment Attachment? @relation(fields:[attachmentId], references:[id]) @@map("invoices") }
model Remito { id Int @id @default(autoincrement()) requestId Int @unique deliveryDate DateTime deliveredTo String observations String? attachmentId Int? createdAt DateTime @default(now()) request Request @relation(fields:[requestId], references:[id]) attachment Attachment? @relation(fields:[attachmentId], references:[id]) @@map("remitos") }
model RequestStatusHistory { id Int @id @default(autoincrement()) requestId Int status RequestStatus comment String? changedById Int changedAt DateTime @default(now()) request Request @relation(fields:[requestId], references:[id], onDelete:Cascade) changedBy User @relation(fields:[changedById], references:[id]) @@map("request_status_history") }
model Attachment { id Int @id @default(autoincrement()) requestId Int? uploadedById Int type AttachmentType fileName String originalName String mimeType String size Int path String url String createdAt DateTime @default(now()) request Request? @relation(fields:[requestId], references:[id], onDelete:SetNull) uploadedBy User @relation(fields:[uploadedById], references:[id]) invoices Invoice[] remitos Remito[] @@map("attachments") }
